{
  "name": "image-key-manager",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "description": "Local web UI for managing OpenAI-compatible image/chat API profiles and generating images with gpt-image-2.",
  "type": "module",
  "scripts": {
    "start": "node --experimental-sqlite server.js",
    "test": "node --experimental-sqlite --test \"test/**/*.test.js\"",
    "backup:generated": "node scripts/generated-backup.js backup",
    "restore:generated": "node scripts/generated-backup.js restore",
    "config:export": "node --experimental-sqlite scripts/system-config.js export",
    "config:import": "node --experimental-sqlite scripts/system-config.js import"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
