# 复制为 .env 后按需修改：Copy-Item .env.example .env

# 宿主机暴露端口。容器内固定使用 8787。
HOST_PORT=8787

# 生产空库初始化首个管理员建议设置长随机值；NODE_ENV=production 且未设置时会拒绝无令牌首个注册。
# 也可作为旧部署兼容令牌，在已有普通用户但没有活跃管理员时初始化管理员。
ADMIN_BOOTSTRAP_TOKEN=

# 仅在生产环境显式设为 1 时允许空库首个注册账号无令牌成为 admin；公网部署不建议启用。
ALLOW_FIRST_ADMIN_WITHOUT_TOKEN=0

# 系统默认接口 API Key 的本地加密主密钥；生产环境必须设置为 32+ 字符随机值才能保存系统 Key。
# 若留空，开发环境兼容旧版明文存储；已加密数据需要同一个值才能解密。
IMAGE_STUDIO_SECRET_KEY=

# 仅在生产环境显式设为 1 时允许系统默认 API Key 明文落库；公网部署不建议启用。
ALLOW_PLAINTEXT_SYSTEM_KEYS=0

# 容器资源限制。下面是 2C/4G 机器承载 10-20 人小团队的保守配置。
CONTAINER_MEMORY_LIMIT=768m
CONTAINER_CPUS=1.25

# Node/V8 heap 上限；必须低于 CONTAINER_MEMORY_LIMIT，给 Buffer/SQLite/native/HTTP body 留余量。
NODE_OPTIONS=--max-old-space-size=384

# 单个 JSON 请求体上限，单位 bytes。默认 1 MiB。
MAX_JSON_BODY_BYTES=1048576

# 单个 multipart 请求体上限，用于上传参考图编辑。默认 64 MiB。
MAX_MULTIPART_BODY_BYTES=67108864

# 单次上游 JSON 响应读取上限，防止超大 base64 / 错误页打满内存。默认 40 MiB。
MAX_UPSTREAM_RESPONSE_BYTES=41943040

# 单次生图最大 n。小机器建议 1，减少单请求内存与磁盘峰值。
MAX_IMAGES_PER_REQUEST=1

# 当 n>1 时，服务端会拆成多个 n=1 上游请求；这里限制单个任务内并发路数。
IMAGE_GENERATION_BATCH_CONCURRENCY=2

# 全站同时生图任务上限。10-20 人小团队建议 3-5；这里取 4。
GLOBAL_CONCURRENT_GENERATIONS=4

# 普通用户默认额度；生图与提示词优化共享次数，管理员可在“管理后台 -> 额度管理”里覆盖。
DEFAULT_DAILY_LIMIT=10
DEFAULT_MONTHLY_LIMIT=200
DEFAULT_STORAGE_LIMIT_MB=500
DEFAULT_CONCURRENT_LIMIT=1

# 注册模式：
# - closed：关闭公开注册；本地/开发空库首个账号仍可自动成为 admin，生产空库首个管理员需 ADMIN_BOOTSTRAP_TOKEN。
# - invite：自助注册必须填写 REGISTRATION_INVITE_CODE。
# - open：允许公开注册，但仍启用 IP 限频。
REGISTRATION_MODE=closed
REGISTRATION_INVITE_CODE=
REGISTRATION_IP_MAX_PER_10MIN=3
REGISTRATION_IP_MAX_PER_DAY=5
REGISTRATION_EMAIL_DOMAIN_ALLOWLIST=
REGISTRATION_EMAIL_DOMAIN_BLOCKLIST=

# 同一个注册 IP 下所有普通账号共享的生图额度池，防止批量注册小号叠加免费额度。
# 留空/0 表示关闭该池；Docker 默认建议值为每日 20、每月 400。
SIGNUP_IP_DAILY_LIMIT=20
SIGNUP_IP_MONTHLY_LIMIT=400

# 上游图片生成超时，单位 ms。默认 10 分钟。
IMAGE_GENERATION_TIMEOUT_MS=600000

# 上游返回 URL 图片的服务端下载边界。
IMAGE_DOWNLOAD_TIMEOUT_MS=60000
MAX_IMAGE_DOWNLOAD_BYTES=26214400

# 参考图编辑输入边界。支持 PNG/JPEG/WebP；图库图会复制到 job 临时目录后再调用上游。
MAX_REFERENCE_IMAGES=4
MAX_REFERENCE_IMAGE_BYTES=12582912
MAX_REFERENCE_IMAGE_TOTAL_BYTES=50331648
REFERENCE_JOB_FILE_TTL_HOURS=24

# SSE 生成接口保活间隔，单位 ms。
GENERATE_STREAM_HEARTBEAT_MS=15000

# Runtime in-memory rate-limit store lifecycle. Set cleanup interval to 0 to sweep on every hit.
RATE_LIMIT_MAX_KEYS=10000
RATE_LIMIT_CLEANUP_INTERVAL_MS=60000

# Gallery filesystem scan caps for list/maintenance paths.
GALLERY_STAT_CONCURRENCY=16
GALLERY_MAINTENANCE_SCAN_PAGE_SIZE=500
GALLERY_ORPHAN_SCAN_MAX_DB_ROWS=50000
GALLERY_ORPHAN_SCAN_MAX_FILES=20000
GALLERY_ORPHAN_SCAN_MAX_DIRS=5000
GALLERY_ORPHAN_SCAN_TIMEOUT_MS=15000

# Docker 停止容器时的优雅关闭等待时间，单位 ms。
SHUTDOWN_TIMEOUT_MS=10000

# SQLite runtime tuning. Keep WAL enabled; these tune contention and checkpoint cadence.
# Set SQLITE_BUSY_TIMEOUT_MS=0 to disable the busy wait, and SQLITE_WAL_AUTOCHECKPOINT_PAGES=0 to disable automatic checkpoints.
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_WAL_AUTOCHECKPOINT_PAGES=1000

# Runtime data lifecycle cleanup. Set any retention value to 0 to disable deleting that table's old rows.
# Sessions are always cleaned when expired.
DATA_CLEANUP_INTERVAL_MS=3600000
AUDIT_LOG_RETENTION_DAYS=180
CLIENT_LOG_RETENTION_DAYS=30
USAGE_DAILY_RETENTION_DAYS=400

# 登录保护：同时按 IP、账号、IP+账号限流，防止变换 login 绕过。
LOGIN_IP_RATE_LIMIT_MAX_PER_MINUTE=20
LOGIN_ACCOUNT_RATE_LIMIT_MAX_PER_MINUTE=8
LOGIN_PAIR_RATE_LIMIT_MAX_PER_MINUTE=5

# 客户端日志上报接口限流；0 表示关闭对应限制。
CLIENT_LOG_RATE_LIMIT_MAX_PER_MINUTE=60
CLIENT_LOG_RATE_LIMIT_WINDOW_MS=60000

# 对话/提示词优化接口保护：防止系统默认 Chat Key 被无限代理消耗。
CHAT_RATE_LIMIT_MAX_PER_MINUTE=20
CHAT_GLOBAL_CONCURRENT_REQUESTS=4
CHAT_MAX_MESSAGES=12
CHAT_MAX_INPUT_CHARS=12000
CHAT_DEFAULT_MAX_COMPLETION_TOKENS=1200
CHAT_MAX_COMPLETION_TOKENS=6000
CHAT_COMPLETION_TIMEOUT_MS=180000

# 接口探活 GET /v1/models 超时，单位 ms。
TEST_PROFILE_TIMEOUT_MS=30000

# 上游安全开关：默认只允许 HTTPS + 公网地址。
# 隔离开发/内网网关才建议打开，生产环境保持 0。
ALLOW_INSECURE_UPSTREAMS=0
ALLOW_PRIVATE_UPSTREAMS=0

# 仅当部署在会清洗 X-Forwarded-For 的可信反向代理后面时设为 1。
TRUST_PROXY=0
# TRUST_PROXY=1 后仅信任这些直连代理 IP（支持 IPv4 CIDR；* 表示兼容旧行为但不推荐）。
TRUST_PROXY_ALLOWED_IPS=127.0.0.1,::1

# 默认匹配 README 的 http://localhost:8787 直连；HTTPS 反向代理部署建议改为 production，或设置 SESSION_COOKIE_SECURE=1，以便 session cookie 带 Secure。
NODE_ENV=development
SESSION_COOKIE_SECURE=0
