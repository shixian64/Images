# 复制为 .env 后按需修改：Copy-Item .env.example .env

# 宿主机暴露端口。容器内固定使用 8787。
HOST_PORT=8787

# 首个管理员注册令牌。首次创建 admin 时必须填写；生产环境请改成长随机值。
ADMIN_BOOTSTRAP_TOKEN=change-me-to-a-long-random-token

# 容器资源限制。下面是 2C/4G 机器承载 10-20 人小团队的保守配置。
CONTAINER_MEMORY_LIMIT=768m
CONTAINER_CPUS=1.25

# Node/V8 heap 上限；建议低于 CONTAINER_MEMORY_LIMIT，给 Buffer/SQLite/native 内存留余量。
NODE_OPTIONS=--max-old-space-size=512

# 单个 JSON 请求体上限，单位 bytes。默认 1 MiB。
MAX_JSON_BODY_BYTES=1048576

# 单次生图最大 n。小机器建议 1，减少单请求内存与磁盘峰值。
MAX_IMAGES_PER_REQUEST=1

# 全站同时生图任务上限。10-20 人小团队建议 3-5；这里取 4。
GLOBAL_CONCURRENT_GENERATIONS=4

# 普通用户默认额度；管理员可在“管理后台 -> 额度管理”里覆盖。
DEFAULT_DAILY_LIMIT=10
DEFAULT_MONTHLY_LIMIT=200
DEFAULT_STORAGE_LIMIT_MB=500
DEFAULT_CONCURRENT_LIMIT=1

# 上游图片生成超时，单位 ms。默认 10 分钟。
IMAGE_GENERATION_TIMEOUT_MS=600000

# SSE 生成接口保活间隔，单位 ms。
GENERATE_STREAM_HEARTBEAT_MS=15000

# Docker 停止容器时的优雅关闭等待时间，单位 ms。
SHUTDOWN_TIMEOUT_MS=10000

# 上游安全开关：默认只允许 HTTPS + 公网地址。
# 隔离开发/内网网关才建议打开，生产环境保持 0。
ALLOW_INSECURE_UPSTREAMS=0
ALLOW_PRIVATE_UPSTREAMS=0

# 如果直接 HTTP 访问容器，保持 development。
# 只有在 HTTPS 反向代理后面部署时才建议改为 production。
NODE_ENV=development
